# =============================================================================
# ANTHROPIC API
# =============================================================================

# Obtén tu clave en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Modelo de Claude a usar para OCR (no cambiar salvo actualización de versión)
CLAUDE_MODEL=claude-sonnet-4-6

# Máximo de tokens en la respuesta por página (4096 es suficiente para una página)
MAX_OUTPUT_TOKENS=4096

# =============================================================================
# PROCESAMIENTO DE IMÁGENES
# =============================================================================

# Resolución PDF → imagen. 200 DPI es buen balance calidad/velocidad.
# Subir a 300 para documentos muy deteriorados (más lento y más costo de tokens).
PDF_DPI=200

# Ancho máximo de la imagen antes de enviar a la API (en píxeles)
IMAGE_MAX_WIDTH=1600

# Factores de mejora de imagen (1.0 = sin cambio, valores mayores aumentan el efecto)
CONTRAST_FACTOR=1.3
SHARPNESS_FACTOR=1.2

# =============================================================================
# COMPORTAMIENTO DEL PIPELINE
# =============================================================================

# Número de reintentos ante errores de API (rate limit, timeouts)
RETRY_ATTEMPTS=3

# Segundos de espera entre reintentos
RETRY_DELAY_SECONDS=5

# Pausa entre páginas (segundos) para no saturar la API
INTER_PAGE_DELAY_SECONDS=1.0
