# =============================================================================
# ANTHROPIC API
# =============================================================================

# Your Anthropic API key. Obtain one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Claude model used for OCR transcription. Do not change unless upgrading versions.
CLAUDE_MODEL=claude-sonnet-4-6

# Maximum tokens allowed in a single API response (one page per request).
MAX_OUTPUT_TOKENS=4096

# =============================================================================
# IMAGE PROCESSING
# =============================================================================

# PDF-to-image resolution in DPI. 200 is a good balance between quality and speed.
# Increase to 300 for heavily degraded documents (slower, higher token cost per page).
PDF_DPI=200

# Maximum image width in pixels before downscaling. Prevents excessive token usage.
IMAGE_MAX_WIDTH=1600

# Enhancement multipliers applied before sending images to the API.
# 1.0 = no change. Values above 1.0 increase contrast/sharpness respectively.
CONTRAST_FACTOR=1.3
SHARPNESS_FACTOR=1.2

# JPEG encoding quality (1-95). 88 gives an excellent quality/size ratio.
# Lower values reduce file size further but may increase [illegible] markers
# on heavily degraded pages. Raise to 92-95 if transcription quality drops.
JPEG_QUALITY=88

# =============================================================================
# PIPELINE BEHAVIOUR
# =============================================================================

# Number of retry attempts on API errors (rate limits, transient failures).
RETRY_ATTEMPTS=3

# Base wait time in seconds between retry attempts.
RETRY_DELAY_SECONDS=5

# Pause in seconds between consecutive page requests to avoid rate limiting.
INTER_PAGE_DELAY_SECONDS=1.0

# =============================================================================
# API SERVER
# =============================================================================

# Comma-separated list of allowed CORS origins.
# Development: http://localhost:3000
# Production:  set to your exact Vercel frontend URL (e.g. https://tausa.vercel.app)
ALLOWED_ORIGINS=http://localhost:3000

# Maximum number of archive chunks shown as citations per query (1–20).
RAG_N_RESULTS=5

# Candidates fetched from ChromaDB before distance filtering (must be >= RAG_N_RESULTS).
RAG_FETCH_CANDIDATES=12

# Maximum cosine distance for a chunk to be included in the context (0.0–1.0).
# Lower = stricter relevance. Raise to 0.70 for broad queries, lower to 0.45 for precision.
RAG_MAX_DISTANCE=0.55

# Enable Anthropic web search to complement archive answers with public historical context.
# Set to false to disable (reduces cost ~$0.01/query but limits answers to archive only).
WEB_SEARCH_ENABLED=true

# Port the uvicorn server listens on. Railway sets this automatically.
PORT=8000
