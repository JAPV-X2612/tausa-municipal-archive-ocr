# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd
*.so

# Virtual environments
.venv/
venv/
env/

# Project data
assets/docs/          # source PDFs — large, not needed by the API
outputs/*.txt         # plain-text transcriptions — only the JSONs are needed
chroma_db/            # rebuilt at container startup via entrypoint.sh
*.db

# Secrets — use env_file or Railway environment variables instead
.env
.env.*
!.env.example

# Version control & IDE
.git/
.gitignore
.idea/
.vscode/

# Development-only files
tests/
scripts/
DELETE/
*.md
